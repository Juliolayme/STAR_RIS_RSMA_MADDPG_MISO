        </mxCell>
        <mxCell id="r_formula" value="r&lt;sub&gt;t&lt;/sub&gt; = 1,5·R̃&lt;sub&gt;sum&lt;/sub&gt; − λ&lt;sub&gt;t&lt;/sub&gt;·Σ&lt;sub&gt;k&lt;/sub&gt; [max(0, R&lt;sub&gt;min&lt;/sub&gt; − R&lt;sub&gt;k&lt;/sub&gt;)]²&lt;br&gt;+ b&lt;sub&gt;pwr&lt;/sub&gt; + b&lt;sub&gt;sat&lt;/sub&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F2F2F2;strokeColor=#000000;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="col_r">
