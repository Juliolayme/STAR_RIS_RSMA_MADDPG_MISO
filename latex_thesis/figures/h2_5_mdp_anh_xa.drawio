        <mxCell id="r_note" value="r&lt;sub&gt;t&lt;/sub&gt; chia sẻ cho cả 3 tác tử (cooperative)" style="text;html=1;align=center;verticalAlign=middle;fontFamily=Helvetica;fontSize=13;fontStyle=2;" vertex="1" parent="col_r">
