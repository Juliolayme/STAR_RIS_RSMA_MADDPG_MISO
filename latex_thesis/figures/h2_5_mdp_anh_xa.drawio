        <mxCell id="r_lambda" value="&lt;b&gt;λ thích nghi&lt;/b&gt;&lt;br&gt;×1,02 nếu QoS &amp;lt; 0,5 · ×0,97 nếu QoS &amp;gt; 0,6&lt;br&gt;λ ∈ [0,3; 13]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="col_r">
          <mxGeometry x="30" y="310" width="420" height="150" as="geometry" />
