        <mxCell id="r_freeze" value="&lt;b&gt;FREEZE-λ&lt;/b&gt;&lt;br&gt;đóng băng λ từ episode 0,55·E = 1100" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1F4E79;strokeWidth=2;fontColor=#1F4E79;fontFamily=Helvetica;fontSize=13;" vertex="1" parent="col_r">
